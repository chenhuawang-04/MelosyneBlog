---
import SiteLayout from '../layouts/SiteLayout.astro';
import Block from '../components/ui/Block.astro';
import CornerMark from '../components/ui/CornerMark.astro';
import Icon from '../components/ui/Icon.astro';
import { SITE_TITLE } from '../consts';
import { getAboutPageData } from '../utils/view-models';
import styles from '../styles/pages/about.module.css';

const pageTitle = `关于 — ${SITE_TITLE}`;
const pageDescription = '关于华旺和这个博客的起源。';
const { links, nowItems, principles, stats, timeline } = await getAboutPageData();
---

<SiteLayout title={pageTitle} description={pageDescription}>
  <main>
    <section class={styles.introGrid}>
      <Block class={styles.identityBlock} style="background: var(--color-ink); color: var(--color-surface);">
        <CornerMark />
        <div class={styles.identityInner}>
          <div class={styles.identityTop}>
            <span class={styles.identityBadge}>
              <Icon name="sparkles" size={14} stroke={2.1} /> Open to ideas
            </span>
            <div class={styles.avatarGrid}>
              <div class={styles.avatarSquare}>HW</div>
              <div class={styles.avatarAccent}></div>
            </div>
          </div>
          <div>
            <h1 class={styles.identityName}>华旺</h1>
            <p class={styles.identityRole}>Writer &middot; Designer &middot; Builder</p>
            <p class={styles.identityBio}>我在注意力很分散的时代，用写作和设计来减速。这个博客是我的个人档案库，也是我思考的公开穿越。</p>
          </div>
        </div>
      </Block>

      <Block class={styles.principlesBlock} style="background: var(--color-gold);">
        <div class={styles.principlesInner}>
          <p class={styles.principlesLabel}>Working principles</p>
          <ul class={styles.principlesList}>
            {principles.map((item, index) => (
              <li class={styles.principlesItem}>
                <span class={styles.principlesNum}>{String(index + 1).padStart(2, '0')}</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </Block>

      <Block class={styles.statsBlock} style="background: var(--color-primary); color: var(--color-surface);">
        <div class={styles.statsInner}>
          {stats.map(({ num, label }) => (
            <div class={styles.statRow}>
              <span class={styles.statNum}>{num}</span>
              <span class={styles.statLabel}>{label}</span>
            </div>
          ))}
        </div>
      </Block>
    </section>

    <section class={styles.midGrid}>
      <Block class={styles.nowBlock} style="background: var(--color-surface);">
        <div class={styles.nowInner}>
          <div class={styles.nowHeader}>
            <span class={styles.nowLabel}>Now</span>
            <span class={styles.nowDot}></span>
          </div>
          <h2 class={styles.nowTitle}>目前正在做的事</h2>
          <ul class={styles.nowList}>
            {nowItems.map((item) => (
              <li class={styles.nowItem}>
                <span class={styles.nowItemDot}></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </Block>

      <Block class={styles.timelineBlock} style="background: var(--color-navy); color: var(--color-surface);">
        <div class={styles.timelineInner}>
          <p class={styles.timelineLabel}>Timeline</p>
          {timeline.map(({ year, event }) => (
            <div class={styles.timelineItem}>
              <span class={styles.timelineYear}>{year}</span>
              <span class={styles.timelineEvent}>{event}</span>
            </div>
          ))}
        </div>
      </Block>
    </section>

    <section class={styles.contactGrid}>
      <Block class={styles.contactBlock} style="background: var(--color-olive); color: var(--color-surface);">
        <div class={styles.contactInner}>
          <p class={styles.contactLabel}>Get in touch</p>
          <h2 class={styles.contactTitle}>来谈谈吧。</h2>
          <div class={styles.contactLinks}>
            {links.map(({ label, icon, href }) => (
              <a href={href} class={styles.contactLink}>
                <Icon name={icon} size={20} stroke={2} />
                <span>{label}</span>
                <Icon name="arrow-up-right" size={16} class={styles.contactArrow} />
              </a>
            ))}
          </div>
        </div>
      </Block>

      <Block class={styles.newsletterBlock} style="background: var(--color-surface);">
        <div class={styles.newsletterInner}>
          <p class={styles.newsletterLabel}>Slow Letter</p>
          <h2 class={styles.newsletterTitle}>一封不追热点的慢通讯。</h2>
          <p class={styles.newsletterDesc}>每周一封，写一个真实问题。不读不罚。</p>
          <form class={styles.newsletterForm}>
            <input type="email" placeholder="you@email.com" class={styles.newsletterInput} />
            <button type="submit" class={styles.newsletterBtn}>
              Subscribe <Icon name="arrow-up-right" size={16} stroke={2.1} />
            </button>
          </form>
        </div>
      </Block>
    </section>
  </main>
</SiteLayout>
