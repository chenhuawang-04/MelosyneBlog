---
interface Props {
  name:
    | 'search'
    | 'arrow-up-right'
    | 'book'
    | 'circle-dot'
    | 'clock'
    | 'feather'
    | 'layout-grid'
    | 'mail'
    | 'sparkles'
    | 'stack-2'
    | 'filter'
    | 'bolt'
    | 'circle-check'
    | 'bookmark'
    | 'star'
    | 'star-filled'
    | 'github'
    | 'rss';
  size?: number;
  stroke?: number;
  class?: string;
}

const { name, size = 24, stroke = 2, class: className = '' } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={stroke}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  {name === 'search' && (
    <>
      <circle cx="11" cy="11" r="7"></circle>
      <path d="m20 20-3.5-3.5"></path>
    </>
  )}
  {name === 'arrow-up-right' && (
    <>
      <path d="M7 17 17 7"></path>
      <path d="M8 7h9v9"></path>
    </>
  )}
  {name === 'book' && (
    <>
      <path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H20v17H6.5A2.5 2.5 0 0 0 4 22z"></path>
      <path d="M8 7h8"></path>
      <path d="M8 11h8"></path>
    </>
  )}
  {name === 'circle-dot' && (
    <>
      <circle cx="12" cy="12" r="9"></circle>
      <circle cx="12" cy="12" r="2.5" fill="currentColor" stroke="none"></circle>
    </>
  )}
  {name === 'clock' && (
    <>
      <circle cx="12" cy="12" r="9"></circle>
      <path d="M12 7v5l3 2"></path>
    </>
  )}
  {name === 'feather' && (
    <>
      <path d="M20 4c-5.5 1-10 5.5-11 11"></path>
      <path d="M4 20c3.5-6.5 9.5-11.5 16-16"></path>
      <path d="M14 6l4 4"></path>
    </>
  )}
  {name === 'layout-grid' && (
    <>
      <rect x="4" y="4" width="6" height="6"></rect>
      <rect x="14" y="4" width="6" height="6"></rect>
      <rect x="4" y="14" width="6" height="6"></rect>
      <rect x="14" y="14" width="6" height="6"></rect>
    </>
  )}
  {name === 'mail' && (
    <>
      <rect x="3" y="5" width="18" height="14" rx="2"></rect>
      <path d="m4 7 8 6 8-6"></path>
    </>
  )}
  {name === 'sparkles' && (
    <>
      <path d="M12 3l1.5 4.5L18 9l-4.5 1.5L12 15l-1.5-4.5L6 9l4.5-1.5L12 3z"></path>
      <path d="M19 14l.8 2.2L22 17l-2.2.8L19 20l-.8-2.2L16 17l2.2-.8L19 14z"></path>
      <path d="M6 15l.7 1.8L8.5 17l-1.8.7L6 19.5l-.7-1.8L3.5 17l1.8-.7L6 15z"></path>
    </>
  )}
  {name === 'stack-2' && (
    <>
      <path d="M12 4 4 8l8 4 8-4-8-4Z"></path>
      <path d="m4 12 8 4 8-4"></path>
      <path d="m4 16 8 4 8-4"></path>
    </>
  )}
  {name === 'filter' && (
    <>
      <path d="M4 6h16"></path>
      <path d="M7 12h10"></path>
      <path d="M10 18h4"></path>
    </>
  )}
  {name === 'bolt' && <path d="M13 2 5 14h5l-1 8 8-12h-5l1-8Z"></path>}
  {name === 'circle-check' && (
    <>
      <circle cx="12" cy="12" r="9"></circle>
      <path d="m8.5 12.5 2.5 2.5 4.5-5"></path>
    </>
  )}
  {name === 'bookmark' && <path d="M7 4h10a1 1 0 0 1 1 1v15l-6-3-6 3V5a1 1 0 0 1 1-1z"></path>}
  {name === 'star' && <path d="m12 3 2.6 5.2 5.7.8-4.1 4 1 5.7L12 16l-5.2 2.7 1-5.7-4.1-4 5.7-.8L12 3z"></path>}
  {name === 'star-filled' && <path d="m12 3 2.6 5.2 5.7.8-4.1 4 1 5.7L12 16l-5.2 2.7 1-5.7-4.1-4 5.7-.8L12 3z" fill="currentColor" stroke="none"></path>}
  {name === 'github' && (
    <>
      <path d="M9 18c-4 1.2-4-2-6-2"></path>
      <path d="M15 21v-3.5a3.1 3.1 0 0 0-.9-2.5c3-.3 6.1-1.5 6.1-6.7A5.2 5.2 0 0 0 18.7 5 4.8 4.8 0 0 0 18.6 2S17.5 1.7 15 3.4a13 13 0 0 0-6 0C6.5 1.7 5.4 2 5.4 2A4.8 4.8 0 0 0 5.3 5 5.2 5.2 0 0 0 3.8 8.3c0 5.1 3.1 6.3 6.1 6.7a3.1 3.1 0 0 0-.9 2.5V21"></path>
    </>
  )}
  {name === 'rss' && (
    <>
      <circle cx="6" cy="18" r="1.5" fill="currentColor" stroke="none"></circle>
      <path d="M5 11a8 8 0 0 1 8 8"></path>
      <path d="M5 6a13 13 0 0 1 13 13"></path>
    </>
  )}
</svg>
